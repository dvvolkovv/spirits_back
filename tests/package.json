{
  "name": "my-linkeon-tests",
  "version": "1.0.0",
  "description": "Automated tests for my.linkeon.io — API, DB, n8n workflows",
  "type": "commonjs",
  "scripts": {
    "test": "node runner.js",
    "test:api": "node runner.js --suite api",
    "test:db": "node runner.js --suite db",
    "test:workflows": "node runner.js --suite workflows",
    "test:e2e": "node runner.js --suite e2e",
    "test:video": "bash video.e2e.sh",
    "test:chat-tools": "bash chat-tools.e2e.sh",
    "smoke": "node smoke/smoke.js",
    "smoke:unit": "jest unit/ --silent",
    "smoke:browser": "playwright test playwright/",
    "smoke:all": "npm run smoke:unit && npm run smoke && npm run smoke:browser"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "jest": "^29.7.0"
  }
}
